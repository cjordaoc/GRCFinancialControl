<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:GRCFinancialControl.Avalonia.ViewModels"
             xmlns:loc="clr-namespace:App.Presentation.Localization;assembly=App.Presentation"
             xmlns:sharedControls="clr-namespace:GRC.Shared.UI.Controls;assembly=GRC.Shared.UI"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="GRCFinancialControl.Avalonia.Views.CustomersView"
             x:DataType="vm:CustomersViewModel">
    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="{StaticResource LayoutMarginSection}" RowSpacing="{StaticResource GridGap}">
        <StackPanel Spacing="{StaticResource SpacingUnit}">
            <TextBlock Grid.Row="0" Text="Customers" Classes="TitleLarge"/>
            <sharedControls:SearchBox Text="{Binding FilterText, Mode=TwoWay}" Placeholder="Search customers..." />
        </StackPanel>

        <sharedControls:EmptyState Grid.Row="1"
                                   Title="No customers found"
                                   Subtitle="Try adjusting your search filter or add new customers."
                                   IsVisible="{Binding !HasCustomers}" />

        <DataGrid Grid.Row="2"
                  IsVisible="{Binding HasCustomers}" ItemsSource="{Binding Customers}" SelectedItem="{Binding SelectedCustomer}" SelectionMode="Single" AutoGenerateColumns="False" IsReadOnly="True" Margin="{StaticResource MarginTopSmall}"
                  CanUserResizeColumns="True"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="Auto"/>
                <DataGridTextColumn Header="Customer Code" Binding="{Binding CustomerCode}" Width="*"/>
                <DataGridTemplateColumn Header="Name" Width="3*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"
                                       TextWrapping="Wrap"
                                       TextTrimming="None"
                                       MinWidth="180"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3"
                    Classes="ButtonRow"
                    HorizontalAlignment="Left"
                    Margin="{StaticResource MarginTopSmall}">
            <Button Content="{loc:Loc Key=FINC_Button_Add}" Command="{Binding AddCommand}" MinWidth="{StaticResource ButtonMinWidth}"/>
            <Button Content="{loc:Loc Key=FINC_Button_Edit}" Command="{Binding EditCommand}" CommandParameter="{Binding SelectedCustomer}" MinWidth="{StaticResource ButtonMinWidth}"/>
            <Button Content="{loc:Loc Key=FINC_Button_View}" Command="{Binding ViewCommand}" CommandParameter="{Binding SelectedCustomer}" MinWidth="{StaticResource ButtonMinWidth}"/>
            <Button Content="{loc:Loc Key=FINC_Button_Delete}" Command="{Binding DeleteCommand}" CommandParameter="{Binding SelectedCustomer}" MinWidth="{StaticResource ButtonMinWidth}"/>
            <Button Content="{loc:Loc Key=FINC_Admin_ClosingPeriods_Button_DeleteData}" Command="{Binding DeleteDataCommand}" CommandParameter="{Binding SelectedCustomer}" Classes="Danger" MinWidth="{StaticResource ButtonMinWidth}"/>
        </StackPanel>
    </Grid>
</UserControl>