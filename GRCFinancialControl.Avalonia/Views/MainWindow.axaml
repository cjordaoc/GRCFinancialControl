<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        xmlns:vm="using:GRCFinancialControl.Avalonia.ViewModels"
        xmlns:converters="using:GRCFinancialControl.Avalonia.Converters"
        xmlns:services="clr-namespace:GRC.Shared.UI.Services;assembly=GRC.Shared.UI"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loc="clr-namespace:App.Presentation.Localization;assembly=App.Presentation"
        xmlns:sharedControls="clr-namespace:GRC.Shared.UI.Controls;assembly=GRC.Shared.UI"
        xmlns:sharedConverters="clr-namespace:GRC.Shared.UI.Converters;assembly=GRC.Shared.UI"
        mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="640"
        x:Class="GRCFinancialControl.Avalonia.Views.MainWindow"
        x:Name="MainWindowRoot"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{loc:Loc Key=FINC_Shell_Title_FinancialControl}"
        TransparencyLevelHint="AcrylicBlur"
        Background="Transparent"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="{StaticResource WindowTitleBarHeight}"
        Padding="{StaticResource WindowClientPadding}"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <sharedConverters:BoolToHorizontalAlignmentConverter x:Key="SidebarAlignmentConverter"
                                                             TrueValue="Left"
                                                             FalseValue="Center" />
    </Window.Resources>

    <Panel>
        <ExperimentalAcrylicBorder IsHitTestVisible="False"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch"
                                   Material="{StaticResource AcrylicModal}"/>

        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="0" Margin="0">
            <sharedControls:SidebarHost Grid.Column="0"
                                        Header="{loc:Loc Key=FINC_Shell_Brand_Primary}"
                                        ExpandedLabel="{loc:Loc Key=Global_SidebarCollapse}"
                                        CollapsedLabel="{loc:Loc Key=Global_SidebarExpand}"
                                        ItemsSource="{Binding NavigationItems}"
                                        CompactWidth="{StaticResource SidebarCompactWidth}"
                                        ExpandedWidth="{StaticResource SidebarExpandedWidth}"
                                        IsExpanded="{Binding IsSidebarExpanded, Mode=TwoWay}">
                <sharedControls:SidebarHost.HeaderTemplate>
                    <DataTemplate>
                        <Border Classes="SidebarHeader">
                            <StackPanel Orientation="Horizontal"
                                    Spacing="12"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType=sharedControls:SidebarHost}, Converter={StaticResource SidebarAlignmentConverter}}">
                                <Border Width="44"
                                        Height="44"
                                        CornerRadius="22"
                                        Background="#30FFFFFF"
                                        BoxShadow="0 2 12 #30000000">
                                    <Path Data="{StaticResource IconHome}"
                                          Width="22"
                                          Height="22"
                                          Stretch="Uniform"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Fill="#FFFFFF"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center"
                                           IsVisible="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType=sharedControls:SidebarHost}}">
                                    <TextBlock Text="{Binding .}"
                                               Classes="TitleMedium"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"
                                               Foreground="#FFFFFF"/>
                                    <TextBlock Text="Financial Control"
                                               FontSize="12"
                                               FontWeight="Normal"
                                               Opacity="0.7"
                                               Foreground="#E0FFFFFF"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </sharedControls:SidebarHost.HeaderTemplate>
                <sharedControls:SidebarHost.ItemTemplate>
                    <DataTemplate x:DataType="vm:NavigationItem">
                        <StackPanel Spacing="2">
                            <ToggleButton Command="{Binding $parent[Window].DataContext.SelectNavigationItemCommand}"
                                          CommandParameter="{Binding}"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          Classes="NavButton"
                                          ToolTip.Tip="{Binding Title}"
                                          ToolTip.Placement="Right"
                                          ToolTip.ShowDelay="500"
                                          HorizontalContentAlignment="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType=sharedControls:SidebarHost}, Converter={StaticResource SidebarAlignmentConverter}}">
                                <ToggleButton.Content>
                                    <Grid ColumnDefinitions="Auto,*">
                                        <Border Grid.Column="0"
                                                Width="44"
                                                Height="44"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center">
                                            <Viewbox Width="24"
                                                     Height="24"
                                                     Margin="10">
                                                <Path Data="{Binding Icon}"
                                                      Fill="#FFFFFF"
                                                      Stretch="Uniform"/>
                                            </Viewbox>
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Title}"
                                                   VerticalAlignment="Center"
                                                   Classes="SidebarTitle"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="NoWrap"
                                                   Margin="8,0,12,0"
                                                   IsVisible="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType=sharedControls:SidebarHost}}"/>
                                    </Grid>
                                </ToggleButton.Content>
                            </ToggleButton>
                            <ItemsControl ItemsSource="{Binding Children}"
                                          Margin="8,6,0,0"
                                          IsVisible="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType=sharedControls:SidebarHost}}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Spacing="2" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:NavigationItem">
                                        <ToggleButton Command="{Binding $parent[Window].DataContext.SelectNavigationItemCommand}"
                                                      CommandParameter="{Binding}"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      Classes="NavButton"
                                                      ToolTip.Tip="{Binding Title}"
                                                      ToolTip.Placement="Right"
                                                      ToolTip.ShowDelay="500"
                                                      HorizontalContentAlignment="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType=sharedControls:SidebarHost}, Converter={StaticResource SidebarAlignmentConverter}}">
                                            <ToggleButton.Content>
                                                <Grid ColumnDefinitions="Auto,*">
                                                     <Border Grid.Column="0"
                                                             Width="44"
                                                             Height="44"
                                                             VerticalAlignment="Center"
                                                             HorizontalAlignment="Center">
                                                         <Viewbox Width="20"
                                                                  Height="20"
                                                                  Margin="12">
                                                             <Path Data="{Binding Icon}"
                                                                   Fill="#FFFFFF"
                                                                   Stretch="Uniform"/>
                                                         </Viewbox>
                                                     </Border>
                                                     <TextBlock Grid.Column="1"
                                                                Text="{Binding Title}"
                                                                VerticalAlignment="Center"
                                                                FontSize="13"
                                                               Classes="SidebarTitle"
                                                               TextTrimming="CharacterEllipsis"
                                                               TextWrapping="NoWrap"
                                                               Margin="6,0,12,0"
                                                               IsVisible="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType=sharedControls:SidebarHost}}"/>
                                                </Grid>
                                            </ToggleButton.Content>
                                        </ToggleButton>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </sharedControls:SidebarHost.ItemTemplate>
            </sharedControls:SidebarHost>

            <Border Grid.Column="1"
                    Classes="Card"
                    Padding="{StaticResource CardPaddingThickness}"
                    Margin="{StaticResource PageMarginThickness}">
                <ContentControl Content="{Binding ActiveView}"
                                IsVisible="{Binding ActiveView, Converter={x:Static converters:ObjectConverters.IsNotNull}}"/>
            </Border>
        </Grid>

        <ItemsControl x:Name="ToastItemsControl"
                      Margin="{StaticResource MarginCallout}"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      ItemsSource="{x:Static services:ToastService.Notifications}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Spacing="{StaticResource ControlSpacing}"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="services:ToastNotification">
                    <sharedControls:ToastNotification AccentBrush="{Binding Type, Converter={StaticResource ToastBrushConverter}}" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Panel>
</Window>