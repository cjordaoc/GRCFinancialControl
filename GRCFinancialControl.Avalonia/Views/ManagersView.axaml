<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:GRCFinancialControl.Avalonia.ViewModels"
             xmlns:loc="clr-namespace:App.Presentation.Localization;assembly=App.Presentation"
             xmlns:sharedControls="clr-namespace:GRC.Shared.UI.Controls;assembly=GRC.Shared.UI"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="GRCFinancialControl.Avalonia.Views.ManagersView"
             x:DataType="vm:ManagersViewModel">
    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="{StaticResource CardPaddingThickness}" RowSpacing="{StaticResource GridGap}">
        <StackPanel Spacing="{StaticResource SpacingUnit}">
            <TextBlock Text="Managers" Classes="TitleLarge" />
            <sharedControls:SearchBox Text="{Binding FilterText, Mode=TwoWay}" Placeholder="Search managers..." />
        </StackPanel>

        <sharedControls:EmptyState Grid.Row="1"
                                   Title="No managers found"
                                   Subtitle="Try adjusting your search filter or add new managers."
                                   IsVisible="{Binding !HasManagers}" />

        <DataGrid Grid.Row="2"
                  IsVisible="{Binding HasManagers}"
                  ItemsSource="{Binding Managers}"
                  SelectedItem="{Binding SelectedManager}"
                  SelectionMode="Single"
                  IsReadOnly="True"
                  AutoGenerateColumns="False"
                  CanUserResizeColumns="True"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="2*"/>
                <DataGridTextColumn Header="Position" Binding="{Binding Position}" Width="*"/>
                <DataGridTextColumn Header="Windows Login" Binding="{Binding WindowsLogin}" Width="2*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3"
                    Classes="ButtonRow"
                    HorizontalAlignment="Left"
                    Margin="{StaticResource MarginTopSmall}">
            <Button Content="{loc:Loc Key=FINC_Button_Add}" Command="{Binding AddCommand}" MinWidth="{StaticResource ButtonMinWidth}"/>
            <Button Content="{loc:Loc Key=FINC_Button_Edit}" Command="{Binding EditCommand}" CommandParameter="{Binding SelectedManager}" MinWidth="{StaticResource ButtonMinWidth}"/>
            <Button Content="{loc:Loc Key=FINC_Button_View}" Command="{Binding ViewCommand}" CommandParameter="{Binding SelectedManager}" MinWidth="{StaticResource ButtonMinWidth}"/>
            <Button Content="{loc:Loc Key=FINC_Button_Delete}" Command="{Binding DeleteCommand}" CommandParameter="{Binding SelectedManager}" Classes="Danger" MinWidth="{StaticResource ButtonMinWidth}"/>
            <Button Content="Edit Assignment" Command="{Binding EditAssignmentCommand}" CommandParameter="{Binding SelectedManager}" MinWidth="{StaticResource ButtonMinWidth}"/>
        </StackPanel>
    </Grid>
</UserControl>